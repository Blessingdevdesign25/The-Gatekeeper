// This is the Prisma schema for The Gatekeeper.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // PostgreSQL for production on Vercel (e.g. Neon, Supabase, Railway).
  // Set DATABASE_URL in Vercel environment variables and GitHub secrets.
  // For local dev, use a local Postgres or a free Neon dev branch.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hash — never the plain-text password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}
